# Local-only development defaults. Do not use these values in production.

COMPOSE_PROJECT_NAME=digital-wallet-agent

POSTGRES_DB=wallet_dev
POSTGRES_USER=wallet
POSTGRES_PASSWORD=wallet_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://wallet:wallet_dev_password@localhost:5432/wallet_dev

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=local-dev-access-secret-change-me
JWT_REFRESH_SECRET=local-dev-refresh-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
OTP_TTL_SECONDS=300
OTP_REQUEST_LIMIT=5
OTP_REQUEST_WINDOW_SECONDS=3600
LOGIN_ATTEMPT_LIMIT=10
LOGIN_ATTEMPT_WINDOW_SECONDS=900
PIN_ATTEMPT_LIMIT=5
PIN_ATTEMPT_WINDOW_SECONDS=3600

AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
KYC_SERVICE_PORT=3003
LEDGER_SERVICE_PORT=3004
WALLET_SERVICE_PORT=3005
LEDGER_SERVICE_URL=http://localhost:3004

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
LOCALSTACK_PORT=4566
LOCALSTACK_DEBUG=0

MAILHOG_SMTP_HOST=localhost
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_URL=http://localhost:8025
MAILHOG_UI_PORT=8025

MOCK_SMS_BASE_URL=http://localhost:8091
MOCK_SMS_PORT=8091
MOCK_PAYMENT_BASE_URL=http://localhost:8092
MOCK_PAYMENT_PORT=8092
MOCK_BILLER_BASE_URL=http://localhost:8093
MOCK_BILLER_PORT=8093
MOCK_AIRTIME_BASE_URL=http://localhost:8094
MOCK_AIRTIME_PORT=8094

OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_PORT=9200
OPENSEARCH_TRANSPORT_PORT=9600
OPENSEARCH_INITIAL_ADMIN_PASSWORD=LocalDevOnly123!

# LocalStack SQS queue names.
QUEUE_AUDIT_EVENTS=audit-events
QUEUE_NOTIFICATION_JOBS=notification-jobs
QUEUE_PROVIDER_CALLBACKS=provider-callbacks
QUEUE_RECONCILIATION_JOBS=reconciliation-jobs
QUEUE_FRAUD_ENRICHMENT=fraud-enrichment
QUEUE_SEARCH_INDEXING=search-indexing

# LocalStack S3 bucket names.
BUCKET_KYC_DOCUMENTS=wallet-kyc-documents-local
BUCKET_RECONCILIATION_REPORTS=wallet-reconciliation-reports-local
BUCKET_AUDIT_ARCHIVE=wallet-audit-archive-local
BUCKET_APP_ARTIFACTS=wallet-app-artifacts-local
