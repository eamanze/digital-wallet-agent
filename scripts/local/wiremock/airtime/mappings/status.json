{
  "request": {
    "method": "GET",
    "urlPathTemplate": "/airtime/status/{reference}"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "status": "successful",
      "provider": "mock-airtime",
      "provider_reference": "{{request.pathSegments.[2]}}"
    }
  }
}

